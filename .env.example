# Externally reachable base URL of the app (scheme + host, no trailing slash).
CH_BASE_URL=http://localhost

# REQUIRED: long random secret that signs session cookies.
# Generate with: openssl rand -hex 32
CH_SESSION_SECRET=

# Session lifetime in hours (default 30 days).
CH_SESSION_TTL_HOURS=720

# Optional: bootstrap a first admin account on startup.
CH_BOOTSTRAP_ADMIN_USERNAME=
CH_BOOTSTRAP_ADMIN_EMAIL=
CH_BOOTSTRAP_ADMIN_PASSWORD=

# OIDC plumbing (set CH_OIDC_ENABLED=true and fill values when ready).
CH_OIDC_ENABLED=false
CH_OIDC_ISSUER_URL=
CH_OIDC_CLIENT_ID=
CH_OIDC_CLIENT_SECRET=
CH_OIDC_REDIRECT_URL=
CH_OIDC_ADMIN_GROUP=

# Logging: debug | info | warn | error
CH_LOG_LEVEL=info

# Comma-separated trusted proxy CIDRs (Caddy is on the compose "web" network).
# Example for the default Docker bridge range:
CH_TRUSTED_PROXIES=172.16.0.0/12
