# Caddy reverse proxy for Capital-Hub.
#
# - Local testing: CH_DOMAIN=localhost serves over HTTP on :80.
# - Production: set CH_DOMAIN to your real domain and Caddy will provision
#   and renew TLS certificates automatically via Let's Encrypt.

{$CH_DOMAIN} {
	encode zstd gzip

	# Forward everything to the app. Caddy sets X-Forwarded-* headers, which the
	# backend trusts when CH_TRUSTED_PROXIES includes the proxy network range.
	reverse_proxy capital-hub:8080 {
		header_up X-Forwarded-Proto {scheme}
		header_up X-Forwarded-Host {host}
	}
}
